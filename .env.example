# Hexa Space RND — environment variables
# Copy this to .env.local for local dev, and add the same as Environment
# Variables in the Vercel dashboard for the deployment.
#
# This instance uses its OWN Supabase project (separate from any other system).

# --- Supabase (frontend, exposed to the browser via Vite) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (serverless api/* functions, server-side only) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Email (Resend) — get from resend.com/api-keys ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- AI (Anthropic / Claude) — get from console.anthropic.com ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Stripe (online invoice payments in the member portal) ---
# Secret key: dashboard.stripe.com → Developers → API keys (server-side only)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Publishable key (safe for the browser; not currently required by the portal
# flow since we use hosted Checkout, but reserved for future card elements)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Webhook signing secret: dashboard.stripe.com → Developers → Webhooks →
# add endpoint https://YOUR-DOMAIN/api/stripe/webhook (event:
# checkout.session.completed) → reveal signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
